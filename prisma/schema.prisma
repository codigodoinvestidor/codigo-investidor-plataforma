generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoLancamento {
  RENDA
  DESPESA
}

// userId vem do Supabase Auth (auth.users.id) — não é uma FK gerenciada pelo Prisma,
// pois a tabela auth.users pertence ao schema interno do Supabase.
//
// mesFim/anoFim nulos = lançamento recorrente sem data de término definida.
// Para lançamento de um único mês, mesFim/anoFim repetem mesInicio/anoInicio.
model LancamentoFinanceiro {
  id           String          @id @default(uuid())
  userId       String
  tipo         TipoLancamento
  categoria    String
  descricao    String
  valor        Decimal         @db.Decimal(12, 2)
  mesInicio    Int
  anoInicio    Int
  mesFim       Int?
  anoFim       Int?
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  @@index([userId])
  @@map("lancamentos_financeiros")
}

enum TipoAtivo {
  ACAO
  FII
  ETF
  RENDA_FIXA
  IMOVEL
  VEICULO
  OUTRO
}

// ticker só se aplica a ativos negociados em bolsa (ACAO, FII, ETF) — usado na Fase 3
// para buscar cotação em tempo real. Para os demais tipos, fica nulo.
model Ativo {
  id                  String    @id @default(uuid())
  userId              String
  tipo                TipoAtivo
  ticker              String?
  nome                String
  quantidade          Decimal   @db.Decimal(18, 6)
  valorCompraUnitario Decimal   @db.Decimal(14, 2)
  dataCompra          DateTime
  percentualIdeal     Decimal?  @db.Decimal(5, 2)
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt

  @@index([userId])
  @@map("ativos")
}

// Registro manual de proventos (dividendos, JSCP, rendimentos) recebidos por ativo.
// A API gratuita de cotações não garante histórico de proventos, então o cadastro é manual.
model Provento {
  id             String   @id @default(uuid())
  userId         String
  ticker         String
  tipoPagamento  String
  valorTotal     Decimal  @db.Decimal(12, 2)
  dataCom        DateTime?
  dataPagamento  DateTime
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@index([userId])
  @@map("proventos")
}

enum TipoOperacao {
  COMPRA
  VENDA
}

// Histórico de operações de compra e venda de ativos.
// Ativos com ticker (bolsa) são agrupados por ticker; ativos sem ticker
// (veículo, imóvel, renda fixa, outro) são agrupados por ativoId, já que
// não há um identificador natural pra casar as operações entre si.
model LancamentoAtivo {
  id            String       @id @default(uuid())
  userId        String
  tipo          TipoOperacao
  ticker        String?
  ativoId       String?
  nome          String?
  quantidade    Decimal      @db.Decimal(18, 6)
  precoUnitario Decimal      @db.Decimal(14, 4)
  valorTotal    Decimal      @db.Decimal(14, 2)
  dataOperacao  DateTime     @db.Date
  corretora     String?
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  @@index([userId])
  @@index([userId, ticker])
  @@index([userId, ativoId])
  @@map("lancamentos_ativos")
}

enum TipoMeta {
  PATRIMONIO
  DIVIDENDOS
}

// Várias metas por tipo são permitidas (ex: "Aposentadoria" e "Casa própria",
// ambas do tipo PATRIMONIO). dataAlvo só faz sentido pra meta de Patrimônio.
model Meta {
  id           String    @id @default(uuid())
  userId       String
  tipo         TipoMeta
  nome         String?
  valorAlvo    Decimal   @db.Decimal(14, 2)
  dataAlvo     DateTime?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([userId, tipo])
  @@map("metas")
}

// Cache compartilhado entre todos os usuários: um ticker é buscado uma vez
// na API de cotações e todos que possuem aquele ativo leem da mesma linha.
model CotacaoAtivo {
  ticker       String   @id
  preco        Decimal  @db.Decimal(14, 2)
  variacaoDia  Decimal? @db.Decimal(8, 4)
  atualizadoEm DateTime @updatedAt

  @@map("cotacoes_ativos")
}

// Cache de séries históricas (preço de tickers e do IBOV) para a tela de Rentabilidade.
// "dados" guarda o array de pontos {data, preco} retornado pela brapi.dev como JSON.
model HistoricoSerie {
  chave        String   @id
  dados        Json
  atualizadoEm DateTime @updatedAt

  @@map("historico_series")
}
